---
const today = new Date();
---
<footer>
	<div class="footer-inner">
		<div class="footer-left">
			<span class="footer-name">Les Hôtels Fassia</span>
			<span class="footer-copy">© {today.getFullYear()} Tous droits réservés.</span>
		</div>

		<div class="footer-right">
			<a href="tel:+224628XXXXXX">+224 628 XX XX XX</a>
			<span class="separator">·</span>
			<a href="tel:+224629XXXXXX">+224 629 XX XX XX</a>
			<span class="separator">·</span>
			<a href="https://www.facebook.com/p/Fassia-Residence-Nongo-100063245107199/" target="_blank" rel="noopener" aria-label="Fassia Nongo Facebook">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
				Nongo
			</a>
			<span class="separator">·</span>
			<a href="https://www.facebook.com/p/Complexe-Hôtelier-Fassia-Guest-House-100083154259327/" target="_blank" rel="noopener" aria-label="Fassia Coyah Facebook">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
				Coyah
			</a>
		</div>
	</div>
</footer>

<style>
	footer {
		background: #09090b;
		border-top: 1px solid #27272a;
		padding: 1.5rem 2rem;
	}

	.footer-inner {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-left {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.footer-name {
		font-family: 'Playfair Display', serif;
		color: #C5A572;
		font-size: 1rem;
	}

	.footer-copy {
		color: #52525b;
		font-size: 0.85rem;
	}

	.footer-right {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.footer-right a {
		color: #a1a1aa;
		text-decoration: none;
		font-size: 0.85rem;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		transition: color 0.2s ease;
	}

	.footer-right a:hover {
		color: #C5A572;
	}

	.separator {
		color: #3f3f46;
		font-size: 0.85rem;
	}

	@media (max-width: 768px) {
		.footer-inner { flex-direction: column; align-items: flex-start; }
		.footer-left { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
	}
</style>