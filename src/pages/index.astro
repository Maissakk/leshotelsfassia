---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title="Les Résidences Fassia - Guinée" description="Deux hôtels d'exception en Guinée" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;500;600&family=Lato:wght@300;400;500&display=swap" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;500;600&family=Lato:wght@300;400;500&display=swap"></noscript>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero">
			<div class="hero-slideshow">
				<div class="hero-slide active" style="background-image: url('/Nongo/Coyah/fassianongomainview.webp')"></div>
				<div class="hero-slide" data-bg="/Nongo/Coyah/fassiacoyahmain.webp"></div>
				<div class="hero-slide" data-bg="/Nongo/Coyah/fassiacoyahhotelroom.webp"></div>
				<div class="hero-slide" data-bg="/Nongo/Coyah/fassianongowedding.webp"></div>
				<div class="hero-slide" data-bg="/Nongo/Coyah/Fassiacoyahpool.webp"></div>
			</div><!-- close hero-slideshow -->

			<div class="hero-overlay"></div>

			<div class="hero-content">
				<h1>Les Résidences Fassia</h1>
				<p class="hero-subtitle">Hospitalité Guinéenne</p>
				<div class="hotels-nav">
					<a href="#nongo" class="hotel-button">Fassia Résidence Nongo</a>
					<a href="#coyah" class="hotel-button">Fassia Guest House Coyah</a>
				</div>
			</div>
			<div class="slide-indicators">
				<button class="indicator active" data-slide="0" aria-label="Diapositive 1"></button>
				<button class="indicator" data-slide="1" aria-label="Diapositive 2"></button>
				<button class="indicator" data-slide="2" aria-label="Diapositive 3"></button>
				<button class="indicator" data-slide="3" aria-label="Diapositive 4"></button>
				<button class="indicator" data-slide="4" aria-label="Diapositive 5"></button>
			</div>
		</section>

		<!-- Intro -->
		<section class="parallax-section fade-in">
			<div class="parallax-bg"></div>
			<div class="intro-content">
				<h2>Une Expérience Inoubliable</h2>
				<div class="divider"></div>
				<p>
					Deux établissements d'exception en Guinée, où l'élégance moderne rencontre
					la chaleur de l'hospitalité africaine. Découvrez nos espaces raffinés et
					notre service personnalisé.
				</p>
			</div>
		</section>

		<!-- Hotels -->
		<section class="hotels-section">

			<!-- NONGO -->
			<div class="hotel-card fade-in-left" id="nongo">
				<div class="hotel-image">
					<img src="/Nongo/Coyah/fassianongomainview.webp" alt="Fassia Résidence Nongo" loading="lazy" width="700" height="550" />
				</div>
				<div class="hotel-info">
					<div class="hotel-label">Conakry</div>
					<h3>Fassia Résidence<br>Nongo</h3>
					<p class="hotel-description">
						Situé dans le quartier résidentiel de Nongo, cet établissement offre un cadre
						moderne et raffiné, idéal pour les voyageurs d'affaires comme pour les loisirs.
					</p>
					<ul class="amenities">
						<li>Chambres climatisées</li>
						<li>Piscine et Terrain de Tennis &amp; Foot</li>
						<li>Bar et room service</li>
						<li>Salles de conférence équipées</li>
						<li>Parking sécurisé</li>
						<li>Wifi haut débit</li>
						<li>Réception 24h/24</li>
					</ul>
				</div>
			</div>

			<!-- NONGO GALLERY -->
			<div class="hotel-gallery stagger-container fade-in">
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassianongohotelroom.webp" alt="Salon de la Chambre Suite" loading="lazy" width="400" height="300" />
					<figcaption>Salon de la Chambre Suite</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassiacoyaheventpool.webp" alt="Piscine" loading="lazy" width="400" height="300" />
					<figcaption>Piscine et Espace pour événement</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassianongoconference.webp" alt="Salle de Conférence" loading="lazy" width="400" height="300" />
					<figcaption>Salle de Conférence Principale</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassianongoroom.webp" alt="Chambre Suite" loading="lazy" width="400" height="300" />
					<figcaption>Chambre Suite</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassianongowedding.webp" alt="Événement" loading="lazy" width="400" height="300" />
					<figcaption>Terrain de Tennis — Événement - Mariage</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassianongoviewfromsea.webp" alt="Espace Extérieur" loading="lazy" width="400" height="300" />
					<figcaption>Espace Extérieur</figcaption>
				</figure>
			</div>

			<div class="hotel-divider"></div>

			<!-- COYAH -->
			<div class="hotel-card fade-in-right" id="coyah">
				<div class="hotel-info">
					<div class="hotel-label">Coyah</div>
					<h3>Fassia Guest<br>House Coyah</h3>
					<p class="hotel-description">
						À une heure de Conakry, la Fassia Guest House propose un séjour calme et
						confortable dans la ville de Coyah, avec toutes les commodités essentielles.
					</p>
					<ul class="amenities">
						<li>Chambres climatisées</li>
						<li>Piscine - Terrain de Tennis &amp; Foot</li>
						<li>Restauration sur place</li>
						<li>Salle de réunion</li>
						<li>Lounge et Boîte de Nuit</li>
						<li>Wifi haut débit</li>
						<li>Réception 24h/24</li>
					</ul>
				</div>
				<div class="hotel-image">
					<img src="/Nongo/Coyah/FassiaCoyahImagePoolandBuilding.webp" alt="Fassia Guest House Coyah" loading="lazy" width="700" height="550" />
				</div>
			</div>

			<!-- COYAH GALLERY -->
			<div class="hotel-gallery stagger-container fade-in">
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassiacoyahchambre.webp" alt="Chambre Standard" loading="lazy" width="400" height="300" />
					<figcaption>Chambre Standard</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassiacoyahlounge2.webp" alt="Lounge et Boîte de nuit" loading="lazy" width="400" height="300" />
					<figcaption>Lounge et Boîte de nuit</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassiacoyahatelier.webp" alt="Salle de Réunion" loading="lazy" width="400" height="300" />
					<figcaption>Séminaire - Salle de Réunion - Ateliers</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassiacoyahrestaurant.webp" alt="Restaurant" loading="lazy" width="400" height="300" />
					<figcaption>Restaurant</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/Fassiacoyahpool.webp" alt="Piscine" loading="lazy" width="400" height="300" />
					<figcaption>Façade de l'Établissement</figcaption>
				</figure>
				<figure class="photo-item stagger-item">
					<img src="/Nongo/Coyah/fassiacoyahtennis.webp" alt="Terrain de Tennis et Façade du 2ème bâtiment" loading="lazy" width="400" height="300" />
					<figcaption>Terrain de Tennis et Façade du 2ème bâtiment</figcaption>
				</figure>
			</div>

		</section>

		<!-- Map & Contact -->
		<section class="map-contact-section bg-dark" id="contact">
			<div class="section-header fade-in">
				<h2 class="text-white">Nous Trouver</h2>
				<div class="divider"></div>
