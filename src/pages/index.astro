<style>
	* { margin: 0; padding: 0; box-sizing: border-box; }

	:root {
		--gold: #C5A572;
		--dark: #18181b;
		--dark2: #27272a;
		--off-white: #fafafa;
	}

	html { scroll-behavior: smooth; }

	body {
		font-family: 'Lato', sans-serif;
		color: #2a2a2a;
		background: white;
		overflow-x: hidden;
	}

	h1, h2, h3 { font-family: 'Playfair Display', serif; font-weight: 400; }

	/* ANIMATIONS */
	.fade-in {
		opacity: 0; transform: translateY(60px);
		transition: opacity 0.8s ease-out, transform 0.8s ease-out;
	}
	.fade-in.visible { opacity: 1; transform: translateY(0); }

	.fade-in-left {
		opacity: 0; transform: translateX(-60px);
		transition: opacity 0.8s ease-out, transform 0.8s ease-out;
	}
	.fade-in-left.visible { opacity: 1; transform: translateX(0); }

	.fade-in-right {
		opacity: 0; transform: translateX(60px);
		transition: opacity 0.8s ease-out, transform 0.8s ease-out;
	}
	.fade-in-right.visible { opacity: 1; transform: translateX(0); }

	.stagger-item {
		opacity: 0; transform: translateY(30px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}
	.stagger-item.visible { opacity: 1; transform: translateY(0); }

	/* HERO */
	.hero { height: 100vh; position: relative; overflow: hidden; }
	.hero-slideshow { position: absolute; width: 100%; height: 100%; }
	.hero-slide {
		position: absolute; width: 100%; height: 100%;
		opacity: 0; transition: opacity 2s ease-in-out;
		background-size: cover; background-position: center;
	}
	.hero-slide.active { opacity: 1; }
	.hero-overlay {
		position: absolute; width: 100%; height: 100%;
		background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.6));
		z-index: 1;
	}
	.hero-content {
		position: relative; z-index: 2; height: 100%;
		display: flex; flex-direction: column;
		justify-content: center; align-items: center;
		text-align: center; color: white; padding: 2rem;
	}
	.hero h1 {
		font-size: clamp(3.5rem, 12vw, 8rem);
		margin-bottom: 1.5rem; font-weight: 300;
		letter-spacing: 3px; text-shadow: 0 3px 30px rgba(0,0,0,0.5);
		animation: heroTitleFadeIn 1.2s ease-out;
	}
	.hero-subtitle {
		font-size: clamp(1rem, 2.5vw, 1.6rem); font-weight: 300;
		letter-spacing: 6px; text-transform: uppercase;
		margin-bottom: 4rem; opacity: 0.95;
		animation: heroSubtitleFadeIn 1.4s ease-out;
	}
	.hotels-nav {
		display: flex; gap: 2rem; flex-wrap: wrap; justify-content: center;
		animation: heroButtonsFadeIn 1.6s ease-out;
	}
	.hotel-button {
		padding: 1.8rem 3.5rem; background: transparent; color: white;
		border: 2px solid white; text-decoration: none;
		font-size: 1rem; letter-spacing: 3px; text-transform: uppercase;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		font-weight: 500; position: relative; overflow: hidden;
	}
	.hotel-button::before {
		content: ''; position: absolute; top: 50%; left: 50%;
		width: 0; height: 0; background: white;
		transition: width 0.4s ease, height 0.4s ease;
		transform: translate(-50%, -50%); z-index: -1; border-radius: 50%;
	}
	.hotel-button:hover::before { width: 300%; height: 300%; }
	.hotel-button:hover { color: var(--dark); transform: translateY(-3px); box-shadow: 0 10px 40px rgba(255,255,255,0.3); }

	.slide-indicators {
		position: absolute; bottom: 3rem; left: 50%; transform: translateX(-50%);
		display: flex; gap: 1rem; z-index: 3;
	}
	.indicator {
		width: 12px; height: 12px; border-radius: 50%;
		background: rgba(255,255,255,0.4); border: 2px solid white;
		cursor: pointer; transition: all 0.3s ease;
	}
	.indicator.active { background: white; transform: scale(1.3); }

	/* INTRO */
	.parallax-section {
		padding: 10rem 2rem; text-align: center; position: relative; overflow: hidden;
	}
	.parallax-bg {
		position: absolute; top: -50%; left: 0; width: 100%; height: 200%;
		background: linear-gradient(135deg, var(--gold) 0%, #d4b88a 100%); opacity: 0.05;
	}
	.intro-content { position: relative; z-index: 2; max-width: 900px; margin: 0 auto; }
	.intro-content h2 { font-size: clamp(2.5rem, 6vw, 4.5rem); margin-bottom: 2rem; color: var(--dark); }
	.intro-content p { font-size: 1.3rem; line-height: 2; color: #6a6a6a; }

	.divider {
		width: 100px; height: 3px; background: var(--gold);
		margin: 3rem auto; position: relative; overflow: hidden;
	}
	.divider::after {
		content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
		animation: shimmer 2s infinite;
	}

	/* HOTEL CARDS */
	.hotels-section { padding: 6rem 2rem; background: var(--off-white); }

	.hotel-card {
		max-width: 1400px; margin: 0 auto 3rem;
		display: grid; grid-template-columns: 1fr 1fr;
		min-height: 550px; background: white; border-radius: 12px; overflow: hidden;
